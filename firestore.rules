rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Users ---
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
      allow delete: if false;

      match /personalStreaks/{streakId} {
        allow read, write: if request.auth.uid == userId;
      }

      match /notifications/{notifId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // --- Pair Invites ---
    match /pairInvites/{inviteId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.fromUserId
            || request.auth.uid == resource.data.toUserId);
      allow delete: if false;
    }

    // --- Pairs ---
    match /pairs/{pairId} {
      function isMember() {
        return request.auth != null
          && (request.auth.uid == resource.data.userIds[0]
              || request.auth.uid == resource.data.userIds[1]);
      }
      function isMemberCreate() {
        return request.auth != null
          && (request.auth.uid == request.resource.data.userIds[0]
              || request.auth.uid == request.resource.data.userIds[1]);
      }

      allow read: if request.auth != null;
      allow create: if isMemberCreate();
      allow update: if isMember();
      allow delete: if false;

      // Plans
      match /plans/{planId} {
        allow read, write: if request.auth != null
          && exists(/databases/$(database)/documents/pairs/$(pairId));
      }

      // Sessions
      match /sessions/{sessionId} {
        allow read, write: if request.auth != null
          && exists(/databases/$(database)/documents/pairs/$(pairId));
      }

      // Streaks
      match /streaks/{streakId} {
        allow read, write: if request.auth != null
          && exists(/databases/$(database)/documents/pairs/$(pairId));
      }
    }
  }
}
